# Copy to .env and fill in values as needed.
# Phase 1 runs fully with the FakeLLMProvider and requires NO keys.

# LLM provider selection: fake | gemini | openai
LPE_LLM_PROVIDER=fake

# Optional Gemini provider (only used if LPE_LLM_PROVIDER=gemini)
GOOGLE_API_KEY=
LPE_GEMINI_MODEL=gemini-1.5-flash

# Optional OpenAI provider (only used if LPE_LLM_PROVIDER=openai)
OPENAI_API_KEY=
LPE_OPENAI_MODEL=gpt-4o-mini

# Chunking defaults
LPE_MAX_CHUNK_TOKENS=4000
LPE_CHUNK_OVERLAP_TOKENS=300
